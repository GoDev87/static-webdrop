# Base domain used for the dropped static websites.
# A folder named "hello" becomes https://hello.sites.example.com
SITES_BASE_DOMAIN=sites.example.com

# External Docker network where Nginx Proxy Manager can reach containers.
# Run: docker network ls
# Then set this to the network used by your NPM container, for example:
# NPM_NETWORK=nginxproxymanager_default
NPM_NETWORK=npm

# Local test port for the static nginx service.
# Open http://hello.sites.example.com:18080 only if your DNS/hosts points there.
STATIC_HTTP_PORT=127.0.0.1:18080

# Where static website folders are stored on your host.
HOST_SITES_DIR=./sites

# Enable/disable Homarr sync.
# Set to 1 after creating a Homarr API key.
HOMARR_ENABLED=0

# Your Homarr base URL from inside Docker.
# Examples:
#   http://homarr:7575
#   http://192.168.1.20:7575
HOMARR_URL=http://homarr:7575

# Homarr API keys are in the format <id>.<token>.
# Create one in Homarr: Management -> Tools -> API -> Authentication.
HOMARR_API_KEY=replace_me

# Official Homarr docs use the ApiKey header. Keep this unless you know you need another mode.
# Options: apikey, bearer, both
HOMARR_AUTH_MODE=apikey

# Default icon used for all created Homarr apps.
HOMARR_ICON_URL=https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons@master/svg/nginx.svg

# Description written into Homarr apps.
HOMARR_DESCRIPTION=Static website managed by static-webdrop

# Watcher interval in seconds.
SCAN_INTERVAL=30

# Delete Homarr apps when the folder disappears?
# Safer default is 0. Set to 1 if you want removals synced too.
DELETE_REMOVED=0
